<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp">

    <!-- TON LINEAR LAYOUT PRINCIPAL -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="?attr/selectableItemBackground">

        <!-- Ligne 1 : Horaire et Prix -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_horaire"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="12/10/2026 à 10:30"
                android:textColor="#1A237E"
                android:textStyle="bold"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tv_prix"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="12.00 €"
                android:textColor="#2E7D32"
                android:textStyle="bold"
                android:textSize="18sp" />
        </LinearLayout>

        <!-- Séparateur -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"
            android:layout_marginVertical="12dp" />

        <!-- Ligne 2 : Itinéraire (Ville Depart) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <View
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@android:color/holo_green_dark"
                android:layout_marginEnd="12dp"/>

            <TextView
                android:id="@+id/tv_depart_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ville Départ"
                android:textColor="#424242"
                android:textSize="15sp" />
        </LinearLayout>

        <!-- Petit trait vertical entre les villes -->
        <View
            android:layout_width="1dp"
            android:layout_height="15dp"
            android:background="#BDBDBD"
            android:layout_marginStart="3dp"
            android:layout_marginVertical="2dp" />

        <!-- Ligne 3 : Itinéraire (Ville Arrivée) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <View
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@android:color/holo_red_dark"
                android:layout_marginEnd="12dp"/>

            <TextView
                android:id="@+id/tv_arrivee_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ville Arrivée"
                android:textColor="#424242"
                android:textSize="15sp" />
        </LinearLayout>

        <!-- Ligne 4 : Places disponibles (en bas à droite) -->
        <TextView
            android:id="@+id/tv_places"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginTop="8dp"
            android:text="3 places restantes"
            android:textColor="#757575"
            android:textSize="12sp"
            android:textStyle="italic" />

    </LinearLayout>
</androidx.cardview.widget.CardView>