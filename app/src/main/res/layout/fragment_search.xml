<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- On met le recycler en premier pour qu'il soit tout en bas -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_results"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/container_small_search"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Elle est en haut, visible uniquement quand on a des résultats -->
    <FrameLayout
        android:id="@+id/container_small_search"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent">
        <androidx.cardview.widget.CardView
            xmlns:android="http://schemas.android.com/apk/res/android"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="25dp"
            app:cardElevation="3dp">

            <LinearLayout
                android:id="@+id/btn_expand_search"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp">

                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@android:color/holo_green_dark" />

                <View
                    android:layout_width="12dp"
                    android:layout_height="1dp"
                    android:background="#BDBDBD"
                    android:layout_marginHorizontal="4dp"/>

                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@android:color/holo_red_dark"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:id="@+id/tv_search_summary"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="Lille → Paris • 12 oct. • 1 pers."
                    android:textColor="#424242"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="24dp"
                    android:background="#EEEEEE"
                    android:layout_marginHorizontal="8dp" />

                <View
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:background="#1A237E" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </FrameLayout>

    <!-- Une vue, invisible par défaut, qui couvre tout l'écran -->
    <View
        android:id="@+id/view_dimmer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#AA000000"
        android:visibility="gone"
        android:elevation="10dp" />

    <!-- Elle est au centre au début, puis en haut pendant le "fading" -->
    <FrameLayout
        android:id="@+id/container_big_search"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:elevation="15dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <androidx.cardview.widget.CardView
            xmlns:android="http://schemas.android.com/apk/res/android"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp">

                <LinearLayout
                    android:id="@+id/btn_select_departure"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="12dp">

                    <View
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:background="@android:color/holo_green_dark"
                        android:layout_marginEnd="16dp" />

                    <TextView
                        android:id="@+id/tv_departure_search"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lieu de départ"
                        android:textColor="#757575"
                        android:textSize="16sp" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#EEEEEE"
                    android:layout_marginHorizontal="12dp" />

                <LinearLayout
                    android:id="@+id/btn_select_arrival"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="12dp">

                    <View
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:background="@android:color/holo_red_dark"
                        android:layout_marginEnd="16dp" />

                    <TextView
                        android:id="@+id/tv_arrival_search"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lieu d'arrivée"
                        android:textColor="#757575"
                        android:textSize="16sp" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#EEEEEE"
                    android:layout_marginHorizontal="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:baselineAligned="false">

                    <LinearLayout
                        android:id="@+id/btn_select_date"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="12dp">

                        <View
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:background="#757575"
                            android:layout_marginEnd="16dp" />

                        <TextView
                            android:id="@+id/tv_date_search"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Aujourd'hui"
                            android:textColor="#424242"
                            android:textSize="15sp" />
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:background="#EEEEEE"
                        android:layout_marginVertical="12dp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <!-- Bouton Moins -->
                        <Button
                            android:id="@+id/btn_minus"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:text="-" />

                        <TextView
                            android:id="@+id/tv_nb_passagers_search"
                            android:layout_width="40dp"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="1"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="#1A237E" />

                        <!-- Bouton Plus -->
                        <Button
                            android:id="@+id/btn_plus"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:text="+" />
                    </LinearLayout>
                </LinearLayout>

                <Button
                    android:id="@+id/btn_search_submit"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="8dp"
                    android:text="Rechercher"
                    android:textAllCaps="false"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/white"
                    app:backgroundTint="#1A237E"
                    app:cornerRadius="12dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
