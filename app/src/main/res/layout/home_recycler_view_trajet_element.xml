<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Ligne 1 : Date/Heure et Label Conducteur -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_horaire_value"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="12/10/2026 à 10:30"
                android:textColor="#1A237E"
                android:textStyle="bold"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tv_conduct_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Jean Dupont"
                android:textColor="#757575"
                android:textSize="14sp"
                android:textStyle="italic" />
        </LinearLayout>

        <!-- Séparateur -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"
            android:layout_marginVertical="12dp" />

        <!-- Ligne 2 : Ville Départ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <View
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@android:color/holo_green_dark"
                android:layout_marginEnd="12dp"/>

            <TextView
                android:id="@+id/tv_depart_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ville Départ"
                android:textColor="#424242"
                android:textSize="15sp" />
        </LinearLayout>

        <!-- Trait vertical de liaison -->
        <View
            android:layout_width="1dp"
            android:layout_height="15dp"
            android:background="#BDBDBD"
            android:layout_marginStart="3dp"
            android:layout_marginVertical="2dp" />

        <!-- Ligne 3 : Ville Arrivée -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <View
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@android:color/holo_red_dark"
                android:layout_marginEnd="12dp"/>

            <TextView
                android:id="@+id/tv_arrivee_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ville Arrivée"
                android:textColor="#424242"
                android:textSize="15sp" />
        </LinearLayout>

        <!-- NOUVEAU : Texte de statut (Affiché quand les boutons sont masqués) -->
        <TextView
            android:id="@+id/tv_statut_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Statut : Accepté"
            android:textAlignment="center"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#2E7D32"
            android:visibility="gone" />

        <!-- Section Actions (Boutons) -->
        <LinearLayout
            android:id="@+id/layout_actions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="20dp">

            <Button
                android:id="@+id/btn_demande_refuser"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/btn_refuser"
                android:textColor="#C62828"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btn_demande_accepter"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:backgroundTint="#2E7D32"
                android:text="@string/btn_accepter"
                android:textColor="@android:color/white"
                android:textSize="14sp" />

        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>